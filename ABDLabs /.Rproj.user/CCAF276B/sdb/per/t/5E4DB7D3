    "contents" : "library(hierfstat)\n#require(qvalue)\n\n######################\n### Some Functions ###\n######################\n\nassert = function(b,s)\n{\n\tif (is.na(b))\n\t{\n\t\tstop(paste0(\"Assert Error (NA received)\", s))\t\n\t}\n\tif (!b)\n\t{\n\t\tstop(paste0(\"Assert Error (FALSE received) \", s))\n\t}\n}\n\nchangeExtension = function(infilepath, newExt){\n  s1 <- unlist(strsplit(x=infilepath, split=\"\\\\/\")) #get the filename from the path\n  filename <- s1[length(s1)]\n  s2 <- unlist(strsplit(x=filename, split=\"\\\\.\"))#separate extension from filename\n  outfile = paste(paste(s2[-length(s2)], collapse=\".\", sep=\"\"), newExt, sep=\"\")\n  outfilepath = paste(paste(s1[-length(s1)],collapse=\"/\"), outfile, sep=\"/\")\n  return(outfilepath)\n}\n\n### For how many generations should the simulations run?\ncomputeNbGenerations = function(m, mutationRate, N)\n{\n\tx = m + mutationRate\n\t# Calculates half life to equilibrium and multiplies it by 50\n  # Whitlock ref\n  L <- (1-x)^2*(1-1/N)\n\tt.half <- log(1/2)/log(L)\n\tgens <- 10*t.half\n  return(floor(gens))\n}\n\n\n\n### Compute FST and Ht\nFSTcalc = function(freqs,WCcalcType=\"NeiFST\")\n{\n\tif (WCcalcType == \"WC\")\n\t{\n\t\t### Assumes all pop sample size are equal\n\t\tmeanFreqs = mean(freqs)\n\t\tHt = 2 * meanFreqs * (1 - meanFreqs)\n\t\tHs = mean(freqs * (1 - freqs) * 2)\n\t\ts2 = sum((freqs - meanFreqs)^2) / (nbDemes-1)\n\n\t\tr_s2_expr = s2 * ((nbDemes - 1) / nbDemes)\n\n\t\tHalfHt = Ht/2\n\n\t\ta = s2 - 1 / (N-1) * (HalfHt - r_s2_expr - Hs / 4)\n\t\tb = N / (N - 1) * (HalfHt - r_s2_expr - ((2*N - 1) * Hs) / (4*N))\n\t\tc = Hs / 2\n\n\t\tFST = a / (a+b+c)\n\n\t\treturn(c(FST, Ht))\n\t}\n\n\tif (WCcalcType == \"WC_old\")\n\t{\n\t\t#### I am doing some simplification here assuming N = sample size (which is the case for our data)\n\t\t#### I took Katie's code as basis\n\t\t#### It seems to return weird values. Incl. many negative values\n\t\tmeanFreqs = mean(freqs)\n\t\tHt = 2 * meanFreqs * (1 - meanFreqs)\n\t\ts2 = sum((freqs - meanFreqs)^2) / (nbDemes-1)\n\t\tT1 = s2   -    1 / (N-1) * (Ht/2)    -    (s2 * (nbDemes-1) / nbDemes)\n\t\tT2 = (N - 1) * (Ht / 2) / (N-1)\n\n\t\tFST = T1 / T2\n\n\t\treturn(c(FST, Ht))\n\t}\n\n\tif (WCcalcType == \"NeiFST\")\n\t{\n\t\tmeanFreqs = mean(freqs)\n\t\tHt = 2 * meanFreqs * (1 - meanFreqs)\n\t\tHs = mean(2 * freqs * (1- freqs))\n\n\t\treturn ( c((Ht - Hs)/Ht, Ht) )\n\t}\n\tstop(\"You have to select one type of WC calculation\")\n}\n\n\n###################\n### PvalueStuff ###\n###################\n\npvalueStuff = function(EmpHt, EmpFST, SimsHt, SimsFST)\n{\n\t###############\n\t### p.value ###\n\t###############\n\n\tpvalues = numeric(nbLoci)\n\tfor (locus in 1:nbLoci)\n\t{\n\t\tHtBinMin = EmpHt[locus] - Ht_halfBinSize\n\t\tHtBinMax = EmpHt[locus] + Ht_halfBinSize\n\n\t\tsimsIndices = which(SimsHt > HtBinMin & SimsHt < HtBinMax)\n\t\tif (length(simsIndices) == 0)\n\t\t{\n\t\t\tpvalues[locus] = NA\n\t\t} else\n\t\t{\n\t\t\tpvalues[locus] = sum(SimsFST[simsIndices] > EmpFST[locus] ) / length(simsIndices)\n\t\t}\n\n\t\tassert(is.na(pvalues[locus]) | (pvalues[locus] >= 0 && pvalues[locus] <= 1), \"is.na(pvalues[locus]) | (pvalues[locus] >= 0 && pvalues[locus] <= 1) is wrong\")\n\t}\n\n\t####################\n\t### FPR NoQvalue ###\n\t####################\n\n\tr = numeric(length(alphas))\n\tfor (alphaIndex in 1:length(alphas))\n\t{\n\t\talpha = alphas[alphaIndex]\n\t\tx = sum(pvalues < alpha) / length(pvalues)\n\t\t#assert(!is.na(x), \"assert !is.na(x) error\")\n\t\tr[alphaIndex] = x\n\t}\n\n\t##############\n\t### qvalue ###\n\t##############\n\n\t# nothing = tryCatch(\n\t# \t{\t\n\t# \t\t#qpvalues = qvalue(pvalues)$qvalues\n\t# \t\tqpvalues = NA\n\t# \t\tfor (alphaIndex in 1:length(alphas))\n\t# \t\t{\n\t# \t\t\talpha = alphas[alphaIndex]\n\t# \t\t\tx = sum(qpvalues < alpha) / length(pvalues)\n\t# \t\t\t#assert(!is.na(x), \"assert !is.na(x) error\")\n\t# \t\t\td[1,colIndex + alphaIndex - 1] = x\n\t# \t\t}\n\t# \t}\n\t# \t,\n\t# \twarning=function(w) {print(paste(\"Warning '\", w,\"' received when running the qvalue function\"))}\n\t# \t,\n\t# \terror=function(e) {print(paste(\"Error '\", e,\"' received when running the qvalue function\"))}\n\t# )\n\t# colIndex = colIndex + length(alphas)\n\n\treturn (r)\n}\n\n\n############################\n### Comand line argument ###\n############################\n\nargs = commandArgs(trailingOnly=TRUE)\nfile_index  = as.numeric(args[[1]])\ngeneralPath = args[[2]]\nprint(paste(\"Fdist2 generalPath = \",generalPath,\"  file_index =\", file_index))\n\n###################\n### Load C code ###\n###################\n\nsetwd(\"/Users/remi/Documents/Biologie/programming/PopGenAnalysis/fdist2/Dryad/srcFDIST2inR\")\ndyn.load(\"src/SimIM.so\")\n\n##################\n### Parameters ###\n##################\n\nsetwd(generalPath)\n\ndecomposeName = function(filename)\n{\n\tm = as.numeric(gsub(\"Rinput_m\", \"\", gsub(\"_BGS.*\",\"\",filename)))\n\tisThereSelection = as.numeric(gsub(paste0(\"Rinput_m\",m,\"_BGS\"), \"\", gsub(\"_generation.*\",\"\",filename)))\n\tgeneration = as.numeric(gsub(paste0(\"Rinput_m\", m, \"_BGS\", isThereSelection, \"_generation\"), \"\", gsub(\"_setIndex.*\",\"\",filename)))\n\tsetIndex = as.numeric(gsub(paste0(\"Rinput_m\", m, \"_BGS\", isThereSelection, \"_generation\", generation, \"_setIndex\"), \"\", gsub(\".dat\",\"\",filename)))\n\treturn (c(m, isThereSelection, generation, setIndex))\n}\n\nalphas = c(0.1, 0.05, 1e-2, 1e-3, 1e-4, 2.5e-5, 1e-5)\nnbDemes = 2\nnbSims =  5e4\nlistOfFiles = list.files(pattern = \"*.dat\")\n\n## Parameters that should not be changed\nN = 1000\nif (generalPath == \"/Volumes/Syldavia/outputFiles/B3.0/Reformat/OneSNPPerSimul_500SNPsPerFile/\")\n{\n\tN = 10000\n}\nHt_binSize = 0.04\nHt_halfBinSize = Ht_binSize / 2\n\n\n#m_complete = (\n#\t\t(1 + EmpAverageFST*(-1 + N) - sqrt(EmpAverageFST*(1 + EmpAverageFST*(-1 + N)))*sqrt(N))/(1 + EmpAverageFST*(-1 + N))\n#\t) * ((nbDemes-1.0) / nbDemes)\n\n\n#print(paste(\n\t#m_complete,\n\t#m_appro\n#))\n\n#m_specialLifeCycle = (EmpAverageFST - EmpAverageFST*N + sqrt(EmpAverageFST*(-1 + N)*(-1 + EmpAverageFST*N)))/(EmpAverageFST - EmpAverageFST*N)\n\nwarningBoundMEst = function(m)\n{\n\tprint(paste0(\"Had to modify m. m computed was \", m))\n}\nboundMEst = function(m)\n{\n\tif (length(m) > 1) {stop(paste0(\"length(m) = \", length(m), \": m = \", paste(m, collapse=\", \")))}\n\tif (is.na(m)) {warningBoundMEst(m); m=0.5}\n\tif (m>0.5)    {warningBoundMEst(m); m=0.5}\n\tif (m<0.0)    {warningBoundMEst(m); m=0.00001}\n\treturn(m)\n}\ncheckLengthArgs = function(f,D,N)\n{\n\tprint(paste0(\"f = \", paste0(f, collapse=\", \")))\n\tprint(paste0(\"D = \", paste0(D, collapse=\", \")))\n\tprint(paste0(\"N = \", paste0(N, collapse=\", \")))\n\tif (length(f)!=1 | length(D)!=1 | length(N)!=1)\n\t{\n\t\tstop(paste0(\"length(f) \", length(f), \" length(D) = \", length(D), \" length(N) = \", length(N)))\n\t}\n}\nMEstMethods = c( # f stands for FST # D for nbDemes and N for population size\n\tfunction(f,D,N) \n\t{\n\t\tcheckLengthArgs(f,D,N)\n\t\tm = - (f-1.0) / (4*D*f*N) # Method used in first submission I think. Check MS\n\t\treturn(boundMEst(m))\n\t},\n\tfunction(f,D,N) \n\t{\n\t\tcheckLengthArgs(f,D,N)\n\t\tm = (1.0/f-1.0) / (2*N) * ((D-1.0) / D) # other m_appro method listed before\n\t\treturn(boundMEst(m))\n\t},\n\tfunction(f,D,N) # m_specialLifeCycle method listed before\n\t{\n\t\tcheckLengthArgs(f,D,N)\n\t\tm = (f - f*N + sqrt(f*(-1 + N)*(-1 + f*N)))/(f - f*N)\n\t\treturn(boundMEst(m))\n\t},\n\tfunction(f,D,N) # Charlesworth 1998 4a\n\t{\n\t\tcheckLengthArgs(f,D,N)\n\t\tm = (-1 + D + f - D * f)/(4 * D * f * N)\n\t\treturn(boundMEst(m))\n\t},\n\tfunction(f,D,N) # Charlesworth 1998 4b\n\t{\n\t\tcheckLengthArgs(f,D,N)\n\t\tm = (-1 + D + f - D * f)/(8 * D * f * N)\n\t\treturn(boundMEst(m))\n\t},\n\tfunction(f,D,N) # Charlesworth 1998 4c\n\t{\n\t\tcheckLengthArgs(f,D,N)\n\t\tm = -(((-1 + D)^2 * (-1 + f))/(4 * D^2 * f * N))\n\t\treturn(boundMEst(m))\n\t}\n)\nnbMEstMethods = length(MEstMethods)\n\n\ninputFile = listOfFiles[file_index]\nprint(paste0(\"inputFile = \", inputFile))\n\npasteAllCombinations = function(x,y)\n{\n\treturn(apply(expand.grid(x, y), 1, paste, collapse=\".\"))\n}\n\n#                                         (       FPRs estimates       )   (empFST)    ( average FST w/wo MAF)    (info)\ndAll = data.frame(matrix(NA,nrow=1, ncol= nbMEstMethods * length(alphas) +    1      +    2 * nbMEstMethods    +   5   ))\ncolnames(dAll) = c(\n\tpasteAllCombinations(\n\t\tpaste0(\"mEst\", 1:nbMEstMethods),\n\t\tpaste0(\"_FPR_Fdist_\", alphas)\n\t),\n\t\"empFST\",\n\tpaste0(\n\t\t\"avSimFST_mEst\",\n\t\t1:nbMEstMethods\n\t),\n\tpaste0(\n\t\t\"avSimFSTMAF_mEst\",\n\t\t1:nbMEstMethods\n\t),\n\t\"m\",\n\t\"isThereSelection\",\n\t\"generation\",\n\t\"setIndex\",\n\t\"fileName\"\n\t)\nempFSTcolumnIn_dAll = which(names(dAll) == \"empFST\")\n\n\n\n############################################\n### Save simulation specificities values ###\n############################################\n\ntmp = decomposeName(inputFile)\nmigr = tmp[1]\nisThereSelection = tmp[2]\ngeneration = tmp[3]\nsetIndex = tmp[4]\ndAll[1,(ncol(dAll)-4):ncol(dAll)] = c(migr, isThereSelection, generation, setIndex, inputFile)\n\n#######################\n### Read input data ###\n#######################\n\ninputDataFstat <- read.fstat(paste0(generalPath,inputFile))\n\n###########################\n### Reformat input data ###\n###########################\n\nL = pop.freq(inputDataFstat)\nassert(all(dim(L[[1]]) == c(nbDemes,nbDemes)), \"Assert to make sure the input data contain the right number of demes and only bi-allelic loci\")\ninputData = t(sapply(1:length(L),function(i){return(L[[i]][1,])}))\nassert(ncol(inputData) == nbDemes, \"Assert on input Data\")\n\n########################################\n### Compute FST and He at each locus ###\n########################################\n\nnbLoci = nrow(inputData) - 1\nEmpFST = numeric(nbLoci)\nEmpHt  = numeric(nbLoci)\nsumNumerator = 0\nsumDenominator = 0\n#numerator = 0.0\n#denominator = 0.0\nfor (locus in 1:nbLoci)\n{\n\tps = inputData[locus,]\n\tpbar = mean(ps)\n\ts2 = var(ps)\n\n\t#numerator \t\t= numerator + s2\n\t#denominator \t= denominator + pbar - pbar^2 + s2/length(ps)\n\tEmpFST[locus] = s2 / (pbar - pbar^2 + s2/length(ps))\n\tEmpHt[locus]  = 2 * pbar * (1-pbar)\n\tsumNumerator = sumNumerator + s2\n\tsumDenominator = sumDenominator + (pbar - pbar^2 + s2/length(ps))\n\tif (EmpHt[locus] < 0.094)\n\t{\n\t\tstop(paste0(\"EmpHt[\", locus, \"] = \", EmpHt[locus], \" < 0.094\"))\n\t}\n}\n\nEmpAverageFST = sumNumerator / sumDenominator\ndAll[1,empFSTcolumnIn_dAll] = EmpAverageFST\n\n\n\nfor (MEstMethods_index in 1:nbMEstMethods)\n{\n\tMEstMethod = MEstMethods[[MEstMethods_index]]\n\n\n\t######################################\n\t### Compute N, m and nbGenerations ###\n\t######################################\n\n\tm = MEstMethod(EmpAverageFST, nbDemes, N)\n\n\tprint(paste0(\"m = \",m))\n\tprint(paste0(\"N = \",N))\n\tprint(paste0(\"nbDemes = \",nbDemes))\n\tprint(paste0(\"EmpAverageFST = \",EmpAverageFST))\n\tprint(paste0(\"mean(EmpFST) = \",mean(EmpFST)))\n\tprint(paste0(\"nbSims = \",nbSims))\n\n\n\tmutationRate = m / 100  \n\tm = m - mutationRate     # Oops that's a bit weird!\n\tprint(paste(\"N = \", N ,\"nbDemes = \", nbDemes, \"EmpAverageFST = \", EmpAverageFST, \" m = \", m))\n\tassert(m >= 0 && m <= 1, \"m >= 0 && m <= 1 is wrong\")\n\n\n\tnbGenerations = computeNbGenerations(m, mutationRate, N)\n\n\tcat(paste0(\"Simulations parameters: m = \", m , \" mutationRate = \", mutationRate, \" N = \", N, \" nbDemes = \", nbDemes, \" nbGenerations = \", nbGenerations, \"\\n\"))\n\n\t################\n\t### Simulate ###\n\t################\n\n\tSimsFST = numeric(nbSims)\n\tSimsHt  = numeric(nbSims)\n\n\tsimIndex = 0\n\tretainedSimIndex = 0\n\n\tprintProgressEvery = max(round(nbSims / 10),1)\n\n\twhile (retainedSimIndex < nbSims)\n\t{\n\t\t#### starting frequency\n\t\tfreqs = rep(runif(1,0,1), nbDemes)\n\n\t\t#### simulate\n\t\tfreqs = .C(\"simulate\", as.double(freqs), as.integer(nbDemes), as.double(mutationRate), as.double(m), as.integer(N), as.integer(nbGenerations))[[1]]\n\n\t\tsimIndex = simIndex + 1\n\n\t\t#### compute FST and Ht\n\t\t# Test if there is some polymorphism\n\t\tsumFreqs = sum(freqs)\n\t\tif (sumFreqs != 0.0 && sumFreqs != 2.0) \n\t\t{\n\t\t\tretainedSimIndex = retainedSimIndex + 1\n\t\t\ttmp = FSTcalc(freqs)\n\t\t\tSimsFST[retainedSimIndex] = tmp[1]\n\t\t\tSimsHt[retainedSimIndex] = tmp[2]\n\t\t}\n\n\t\t#### Print progress\n\n\t\tif (simIndex%%printProgressEvery == 0)\n\t\t{\n\t\t\tcat(paste0(\"Kept \",retainedSimIndex, \" out of \", simIndex,\"\\n\"))\n\t\t}\n\t}\n\tcat(paste0(\"Kept \",retainedSimIndex, \" out of \", simIndex,\"\\n\"))\n\n\t#### Print stuff\n\tAverageSimulatedFST = mean(SimsFST, na.rm=TRUE)          # Oops that's a bit weird! Comparing Gst to WCst (EmpAverageFST is WCst)\n\tAverageSimulatedFSTMAF = mean(SimsFST[SimsHt>=0.095])\n\tprint(paste(\"Average simulated FST = \", AverageSimulatedFST))\n\tprint(paste(\"Average simulated MAF 0.05 FST = \", AverageSimulatedFSTMAF))\n\tprint(paste(\"Average empirical FST = \", EmpAverageFST))\n\n\n\t###################\n\t### pvalueStuff ###\n\t###################\n\n\tFPR_estimates = pvalueStuff(EmpHt, EmpFST, SimsHt, SimsFST)\n\n\tl = length(alphas)\n\tb = (MEstMethods_index - 1) * l + 1\n\te = (MEstMethods_index) * l\n\tassert(l == length(FPR_estimates), \"l == length(FPR_estimates) is wrong\")\n\tassert(b <= e, \"b <= e is wrong\")\n\tassert((e - b + 1) == length(FPR_estimates), \"(e - b + 1) == length(FPR_estimates) is wrong\")\n\tassert(e < empFSTcolumnIn_dAll, \"e < empFSTcolumnIn_dAll is wrong\")\n\tdAll[1, b:e] = FPR_estimates\n\tdAll[1, empFSTcolumnIn_dAll + MEstMethods_index] = AverageSimulatedFST\n\tdAll[1, empFSTcolumnIn_dAll + nbMEstMethods + MEstMethods_index] = AverageSimulatedFSTMAF\n\n\n\t############################\n\t### Rescales pvalueStuff ###\n\t############################\n\n\t#SimsFST = SimsFST / mean(SimsFST[SimsHt>0.05]) * EmpAverageFST\n\t#SimsHt = SimsHt / mean(SimsHt[SimsHt>0.05]) * mean(EmpHt)\n\n\t#d = pvalueStuff(d,EmpHt, EmpFST, SimsHt, SimsFST, colIndex)\n\n}\n\n#####################\n### Write outputs ###\n#####################\n\noutputFile = substring(changeExtension(inputFile, \".FdistFPR\"),2)\n\nassert(nrow(dAll) == 1, \"d does not have exactly one row!\")\n\nprintf(paste(\"output at '\", paste0(generalPath, outputFile),\"'\"))\nwrite.table(dAll,paste0(generalPath, outputFile), quote=FALSE, row.names=FALSE)\n\ncat(\"Done!\\n\")\n\n\n",
